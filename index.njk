<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
  <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

<header>
  <div class="header-container">
    <img src="/images/logo.ico" alt="Service EPGT" class="logo">
    <nav>
      <ul>
        <li><a href="/">Accueil</a></li>
        <li><a href="#articles">Articles</a></li>
        <li><a href="/contact">Contact</a></li>
	    <li><a href="/a-propos/">À propos</a></li>
	    <li><a href="/services/">Services</a></li>
		<li><a href="/contact">Contact</a></li>
        <li><a href="/admin/">Admin</a></li>
      </ul>
    </nav>
  </div>
  <div class="lang-switcher">
    <a href="?lang=fr">FR</a> | <a href="?lang=en">EN</a>
  </div>
</header>

<main>
  <section id="articles">
    <h2>Nos derniers articles</h2>
    <div class="articles-container">
      {% for article in collections.articles %}
        <div class="article-card">
          <h3>{{ article.data.title }}</h3>
          <p>{{ article.date | date("dd/LL/yyyy") }}</p>
          <p>{{ article.templateContent | striptags | truncate(120, true, "...") }}</p>
          <a href="{{ article.url }}">Lire plus</a>
        </div>
      {% endfor %}
    </div>
  </section>
</main>

<footer>
  <div class="footer-container">
    <p>© 2025 - Service EPGT | Développé par Parfait Esaie</p>
    <nav>
      <ul class="footer-menu">
        <li><a href="/">Accueil</a></li>
        <li><a href="#articles">Articles</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
  </div>
</footer>

</body>
</html>
